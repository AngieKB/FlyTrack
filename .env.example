# Archivo de configuración de ambientes
# Copiar a .env para usar
# NO SUBIR .env al repositorio (está en .gitignore)

# ============================================
# AMBIENTE - Desarrollo/Staging/Producción
# ============================================
ENVIRONMENT=development
# Valores: development, staging, production

# ============================================
# BASE DE DATOS
# ============================================
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=flytrack_db
DB_USER=root
DB_PASSWORD=root
DB_ROOT_PASSWORD=root

# ============================================
# SPRING BOOT
# ============================================
SPRING_PROFILES_ACTIVE=development
SERVER_PORT=8080

# ============================================
# SEGURIDAD
# ============================================
SECURITY_USER=admin
SECURITY_PASSWORD=admin123

# ============================================
# DOCKER REGISTRY
# ============================================
REGISTRY_URL=ghcr.io
REGISTRY_USER=tu-usuario
REGISTRY_PASSWORD=tu-token-personal

# ============================================
# SONARQUBE (Opcional)
# ============================================
# SONARQUBE_HOST=http://localhost:9000
# SONARQUBE_TOKEN=token-aqui

# ============================================
# KUBERNETES (Opcional)
# ============================================
# K8S_NAMESPACE=default
# K8S_CONTEXT=docker-desktop

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
# Valores: DEBUG, INFO, WARN, ERROR

